# MongoDB (Mongoose)
# Atlas `mongodb+srv`: app pehle HTTPS (DNS-over-HTTPS, Google / Cloudflare) se SRV/TXT resolve karti hai — UDP `querySrv` bypass.
# Ye band karne ke liye (sirf zarurat ho tab): MONGODB_SRV_DOH=off
# Custom DoH bases (comma-separated, optional): MONGODB_DOH_ENDPOINTS="https://dns.google/resolve,..."
# Atlas: fallback — dashboard se standard mongodb://... comma-host string use karo.
# Password me @ : / # ? ho to URI me encode karo (@ → %40). Galat: ...:pass@word@cluster...  Sahi: ...:pass%40word@cluster...
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0"
# Atlas auth: error `bad auth` → DB user/password check; Node: encodeURIComponent('your-password')
# Atlas: Network Access (IP) + Database Access (user + readWrite) dono set hon.

# Windows + mongodb+srv: app by default Node ke liye public DNS (8.8.8.8) set karti hai. Corporate VPN par band karo:
# MONGODB_SRV_DNS=off
# Linux/macOS par same fix ke liye: MONGODB_SRV_DNS=public
# Optional custom resolvers (comma-separated):
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# NextAuth — non-empty in production; local dev uses a built-in fallback if unset
NEXTAUTH_SECRET="generate-a-long-random-string"
# Local: http://localhost:3000  |  Vercel: https://your-project.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Single admin account (credentials provider)
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="change-me"

# Cloudinary — direct image upload from CMS (optional; image button falls back to URL)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY="782325681485923"
CLOUDINARY_API_SECRET="GAvAXh4YB7leYkVz7rhp1zykgnA"
# Optional folder for uploads
CLOUDINARY_UPLOAD_FOLDER="gate-questions"

# Allow extra HTTPS image hosts for stems/options (comma-separated). Cloudinary (*.cloudinary.com), / uploads, and localhost in dev need no env.
NEXT_PUBLIC_IMAGE_HOSTS=""

# Groq — short AI recap shown after answering (practice / PYQ question card). Server-side only.
GROQ_API_KEY=""
# Optional; default llama-3.3-70b-versatile — see Groq docs for current models.
GROQ_MODEL=""
